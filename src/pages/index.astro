<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Futile Studio — Mayur</title>
  <meta name="description" content="Everything is futile at scale. We do it anyway, because there's beauty in it." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Space+Mono:ital@0;1&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0c0b09;
      --surface:   #141210;
      --border:    #2a2620;
      --cream:     #e6ddd0;
      --muted:     #7a7062;
      --faint:     #2e2a24;
      --rust:      #c4622d;
      --rust-lt:   #d4874a;
      --serif:     'Playfair Display', Georgia, serif;
      --mono:      'Space Mono', 'Courier New', monospace;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--cream);
      font-family: var(--mono);
      font-size: 14px;
      line-height: 1.7;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* grain overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      opacity: 0.04;
      pointer-events: none;
      z-index: 999;
    }

    /* nav */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 48px;
      background: linear-gradient(to bottom, var(--bg) 0%, transparent 100%);
    }

    .nav-logo {
      font-family: var(--serif);
      font-size: 16px;
      letter-spacing: 0.02em;
      color: var(--cream);
      text-decoration: none;
    }

    .nav-logo span { color: var(--rust); }

    nav ul {
      list-style: none;
      display: flex;
      gap: 32px;
    }

    nav a {
      color: var(--muted);
      text-decoration: none;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    nav a:hover { color: var(--cream); }

    /* hero */
    .hero {
      min-height: 100vh;
      display: grid;
      place-items: center;
      text-align: center;
      padding: 120px 48px 80px;
      position: relative;
    }

    .hero-inner { max-width: 720px; }

    .label {
      display: inline-block;
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--rust);
      margin-bottom: 24px;
    }

    h1 {
      font-family: var(--serif);
      font-size: clamp(48px, 8vw, 96px);
      font-weight: 400;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--cream);
      margin-bottom: 32px;
    }

    h1 em {
      font-style: italic;
      color: var(--rust-lt);
    }

    .hero-sub {
      font-size: 15px;
      color: var(--muted);
      max-width: 480px;
      margin: 0 auto 48px;
      line-height: 1.9;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border: 1px solid var(--border);
      color: var(--cream);
      text-decoration: none;
      padding: 12px 24px;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: border-color 0.2s, color 0.2s;
    }

    .hero-cta:hover { border-color: var(--rust); color: var(--rust-lt); }
    .hero-cta svg { width: 14px; height: 14px; }

    /* vinyl decorative */
    .vinyl-deco {
      position: absolute;
      right: -80px;
      top: 50%;
      transform: translateY(-50%);
      width: 340px;
      height: 340px;
      opacity: 0.08;
      animation: spin 40s linear infinite;
    }

    @keyframes spin { to { transform: translateY(-50%) rotate(360deg); } }

    /* sections */
    section { padding: 100px 48px; max-width: 1100px; margin: 0 auto; }

    .section-label {
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--rust);
      margin-bottom: 16px;
    }

    h2 {
      font-family: var(--serif);
      font-size: clamp(28px, 4vw, 48px);
      font-weight: 400;
      line-height: 1.1;
      margin-bottom: 40px;
      color: var(--cream);
    }

    .divider {
      width: 100%;
      height: 1px;
      background: var(--border);
      margin: 0 48px;
      max-width: calc(1100px - 96px);
    }

    /* about */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: start;
    }

    .about-text p {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.9;
      margin-bottom: 20px;
    }

    .about-text p strong { color: var(--cream); font-weight: 400; }

    .philosophy-quote {
      border-left: 2px solid var(--rust);
      padding-left: 28px;
      margin-top: 40px;
    }

    .philosophy-quote blockquote {
      font-family: var(--serif);
      font-style: italic;
      font-size: 22px;
      line-height: 1.5;
      color: var(--cream);
      opacity: 0.85;
    }

    .philosophy-quote cite {
      display: block;
      margin-top: 12px;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      font-style: normal;
    }

    /* stack cards */
    .stack-list {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .stack-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 0;
      border-bottom: 1px solid var(--border);
      font-size: 12px;
    }

    .stack-item span:first-child { color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
    .stack-item span:last-child  { color: var(--cream); }

    /* projects */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 24px;
    }

    .project-card {
      border: 1px solid var(--border);
      padding: 28px;
      background: var(--surface);
      transition: border-color 0.2s;
      cursor: pointer;
      text-decoration: none;
      display: block;
      color: inherit;
    }

    .project-card:hover { border-color: var(--rust); }

    .project-tag {
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--rust);
      margin-bottom: 12px;
    }

    .project-name {
      font-family: var(--serif);
      font-size: 20px;
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 10px;
    }

    .project-desc {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.8;
    }

    .project-arrow {
      margin-top: 20px;
      font-size: 11px;
      letter-spacing: 0.1em;
      color: var(--rust);
      text-transform: uppercase;
    }

    /* recording */
    .recording-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 48px;
      flex-wrap: wrap;
      gap: 16px;
    }

    .recording-header p {
      font-size: 13px;
      color: var(--muted);
      max-width: 360px;
      line-height: 1.8;
    }

    .vinyl-shelf {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 16px;
    }

    .vinyl-item {
      aspect-ratio: 1;
      background: var(--surface);
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 14px;
      position: relative;
      overflow: hidden;
      cursor: pointer;
      transition: border-color 0.2s;
    }

    .vinyl-item:hover { border-color: var(--rust); }

    .vinyl-item .vinyl-bg {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0.12;
    }

    .vinyl-item .vinyl-bg svg { width: 80%; height: 80%; }

    .vinyl-title {
      font-family: var(--serif);
      font-size: 14px;
      color: var(--cream);
      position: relative;
      z-index: 1;
    }

    .vinyl-artist {
      font-size: 11px;
      color: var(--muted);
      position: relative;
      z-index: 1;
      margin-top: 2px;
    }

    .vinyl-format {
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--rust);
      position: relative;
      z-index: 1;
      margin-top: 6px;
    }

    .add-tile {
      aspect-ratio: 1;
      border: 1px dashed var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--faint);
    }

    /* thoughts */
    .thoughts-list {
      display: flex;
      flex-direction: column;
    }

    .thought-item {
      display: grid;
      grid-template-columns: 100px 1fr;
      gap: 32px;
      padding: 28px 0;
      border-bottom: 1px solid var(--border);
      align-items: start;
      text-decoration: none;
      color: inherit;
      transition: opacity 0.2s;
    }

    .thought-item:hover { opacity: 0.7; }

    .thought-date {
      font-size: 11px;
      letter-spacing: 0.06em;
      color: var(--muted);
      padding-top: 4px;
    }

    .thought-title {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 8px;
    }

    .thought-preview {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.8;
    }

    /* footer */
    footer {
      border-top: 1px solid var(--border);
      padding: 48px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      max-width: 1100px;
      margin: 0 auto;
      flex-wrap: wrap;
      gap: 16px;
    }

    .footer-logo {
      font-family: var(--serif);
      font-size: 14px;
      color: var(--muted);
    }

    .footer-links {
      display: flex;
      gap: 24px;
      list-style: none;
    }

    .footer-links a {
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-links a:hover { color: var(--rust); }

    .footer-copy {
      font-size: 11px;
      color: var(--faint);
      letter-spacing: 0.04em;
    }

    @media (max-width: 768px) {
      nav { padding: 20px 24px; }
      nav ul { gap: 20px; }
      section { padding: 72px 24px; }
      .about-grid { grid-template-columns: 1fr; gap: 40px; }
      .recording-header { flex-direction: column; }
      .thought-item { grid-template-columns: 1fr; gap: 8px; }
      footer { padding: 40px 24px; flex-direction: column; align-items: flex-start; }
      .vinyl-deco { display: none; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <a href="#" class="nav-logo">Futile<span>.</span>Studio</a>
    <ul>
      <li><a href="#about">About</a></li>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#homelab">Homelab</a></li>
      <li><a href="#recording">Recording Co</a></li>
      <li><a href="#thoughts">Thoughts</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <div class="hero">
    <!-- Vinyl decoration -->
    <svg class="vinyl-deco" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="100" cy="100" r="99" stroke="white" stroke-width="1"/>
      <circle cx="100" cy="100" r="88" stroke="white" stroke-width="0.5"/>
      <circle cx="100" cy="100" r="76" stroke="white" stroke-width="0.5"/>
      <circle cx="100" cy="100" r="64" stroke="white" stroke-width="0.5"/>
      <circle cx="100" cy="100" r="52" stroke="white" stroke-width="0.5"/>
      <circle cx="100" cy="100" r="40" stroke="white" stroke-width="0.5"/>
      <circle cx="100" cy="100" r="28" stroke="white" stroke-width="0.5"/>
      <circle cx="100" cy="100" r="16" stroke="white" stroke-width="1"/>
      <circle cx="100" cy="100" r="6"  fill="white" opacity="0.6"/>
    </svg>

    <div class="hero-inner">
      <span class="label">futile.studio / est. 2025</span>
      <h1>Everything is<br><em>futile.</em><br>Do it anyway.</h1>
      <p class="hero-sub">
        We are here briefly. At scale, nothing persists. Yet there is something worth doing
        in the making — of music, of software, of objects that outlast you.
      </p>
      <a href="#about" class="hero-cta">
        Explore the studio
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="divider"></div>

  <!-- ABOUT -->
  <section id="about">
    <div class="about-grid">
      <div class="about-text">
        <div class="section-label">/ About</div>
        <h2>The person<br>behind the work</h2>
        <p>
          I'm Mayur. I build things — software, recordings, collections — with the full awareness
          that <strong>none of it matters at a cosmic scale.</strong> That's the point.
        </p>
        <p>
          Futile Studio is my personal corner of the internet. It's where my projects live,
          where my thoughts collect dust until they're worth reading, and where Futile Recording Co
          keeps a log of every piece of music that moved me enough to own it physically.
        </p>
        <p>
          I collect vinyls and cassettes. Physical media. Things that represent a moment,
          an emotion, a sound that mattered. They'll outlast me. So will the code, if it's good enough.
        </p>
        <p>
          I also run a homelab. My server is called <strong>jinx</strong> — Ubuntu Server,
          self-hosted stack running Docker, Proxmox, Tailscale, Nginx Proxy Manager, Vaultwarden,
          Coolify, and more cool stuff<strong>*.futile.studio</strong>.
          I got into it because I wanted to understand infrastructure at the bare metal level —
          total control, every detail known, nothing abstracted away.
        </p>

        <div class="philosophy-quote">
          <blockquote>
            "We are on this planet for a brief time. The scale makes everything futile.
            The beauty is in doing it anyway."
          </blockquote>
          <cite>— Mayur, futile.studio</cite>
        </div>
      </div>

      <div>
        <div class="section-label">/ The stack</div>
        <div class="stack-list">
          <div class="stack-item"><span>Building</span><span>Software &amp; infrastructure</span></div>
          <div class="stack-item"><span>Collecting</span><span>Vinyl &amp; cassettes</span></div>
          <div class="stack-item"><span>Making</span><span>Music / Futile Rec. Co</span></div>
          <div class="stack-item"><span>Homelabbing</span><span>Jinx everything</span></div>
          <div class="stack-item"><span>Based in</span><span>Paderborn, Germany</span></div>
        </div>
        <a href="/cv.pdf" download="Mayur_Jivani_CV.pdf" class="hero-cta" style="margin-top:32px;display:inline-flex">
          Download CV
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M8 3v7M5 7l3 3 3-3M3 13h10"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- PROJECTS -->
  <section id="projects">
    <div class="section-label">/ Projects</div>
    <h2>Things I've built<br>& shipped</h2>

    <div class="projects-grid">

      <a href="https://projects.futile.studio/qno" target="_blank" rel="noopener" class="project-card">
        <div class="project-tag">Game · Dec 2025</div>
        <div class="project-name">Qno</div>
        <div class="project-desc">A quantum-themed Uno card game built to teach quantum computing — superposition, entanglement, quantum gates — through multiplayer gameplay. React.js, Node.js, WebSockets.</div>
        <div class="project-arrow">Play →</div>
      </a>

      <a href="https://projects.futile.studio/mosaic" target="_blank" rel="noopener" class="project-card">
        <div class="project-tag">Video · 2025</div>
        <div class="project-name">Mosaic</div>
        <div class="project-desc">Multi-screen video mosaic canvas — sync playback across devices, clip routing to individual viewers, and LAN-friendly uploads. Astro, React, WebSockets.</div>
        <div class="project-arrow">Open →</div>
      </a>

      <a href="https://github.com/mayurjivani" target="_blank" rel="noopener" class="project-card">
        <div class="project-tag">Music · Jan 2024</div>
        <div class="project-name">Chorus</div>
        <div class="project-desc">A Wordle-inspired music guessing game with Spotify integration. Pulls your listening history, streams audio in-browser via Spotify Playback SDK. React.js.</div>
        <div class="project-arrow">View project →</div>
      </a>

      <a href="https://github.com/mayurjivani" target="_blank" rel="noopener" class="project-card">
        <div class="project-tag">Backend · 2024</div>
        <div class="project-name">HiLearn CRM</div>
        <div class="project-desc">A full lead management and CRM system for an education platform — Meta Leads Webhook, call tracking, follow-up workflows, enrollment pipelines. Node.js, Express, PostgreSQL.</div>
        <div class="project-arrow">View project →</div>
      </a>

      <a href="https://github.com/mayurjivani" target="_blank" rel="noopener" class="project-card">
        <div class="project-tag">Platform · 2024</div>
        <div class="project-name">Fly The Nest</div>
        <div class="project-desc">Online education platform serving 150+ students. Built the backend, Zoom SDK virtual classroom integration, and AI-powered interview prep via LanguifyAI. Node.js, React.js.</div>
        <div class="project-arrow">View project →</div>
      </a>

    </div>
  </section>

