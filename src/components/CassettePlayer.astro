---
// Tape deck modal — populated and controlled by /collection page script.
// Expects a shared <audio id="media-audio"> to exist on the page.
---

<div class="player cassette-player" id="cassette-player" data-format="cassette" aria-hidden="true">
	<div class="player-panel">
		<button class="player-close" id="cassette-close" aria-label="Close player">✕</button>

		<div class="player-label">/ TAPE DECK — DWG 02</div>

		<div class="deck">
			<div class="cassette" id="cassette-body">
				<div class="cassette-window">
					<div class="reel" id="reel-left">
						<div class="reel-hub"></div>
					</div>
					<div class="tape-strip"></div>
					<div class="reel" id="reel-right">
						<div class="reel-hub"></div>
					</div>
				</div>
				<div class="cassette-label">
					<span id="cassette-title">Album Title</span>
					<span id="cassette-artist">Artist</span>
				</div>
				<div class="cassette-screws">
					<span></span><span></span><span></span><span></span>
				</div>
			</div>
		</div>

		<div class="player-meta">
			<div>
				<div class="meta-title" id="cassette-meta-title">Album Title</div>
				<div class="meta-sub" id="cassette-meta-sub">Artist · Year</div>
			</div>
			<div class="format-badge">CASSETTE</div>
		</div>

		<div class="player-controls">
			<button class="transport-btn" id="cassette-play" aria-label="Play / pause">
				<svg id="cassette-play-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M4 2.5v11l10-5.5-10-5.5z"></path></svg>
				<svg id="cassette-pause-icon" viewBox="0 0 16 16" fill="currentColor" style="display:none"><path d="M4 2.5h3v11H4zM9 2.5h3v11H9z"></path></svg>
			</button>
			<div class="scrub">
				<span class="time counter" id="cassette-time-current">000</span>
				<div class="scrub-track"><div class="scrub-fill" id="cassette-scrub-fill"></div></div>
				<span class="time counter" id="cassette-time-total">000</span>
			</div>
		</div>

		<p class="player-note" id="cassette-note"></p>
	</div>
</div>

<style>
	.player {
		position: fixed;
		inset: 0;
		z-index: 300;
		display: none;
		align-items: center;
		justify-content: center;
		padding: 24px;
		background: rgba(4, 8, 16, 0.86);
		backdrop-filter: blur(6px);
	}
	.player.is-open {
		display: flex;
	}

	.player-panel {
		position: relative;
		width: min(520px, 100%);
		background: var(--surface);
		border: 1px solid var(--line-strong);
		padding: 36px;
	}

	.player-close {
		position: absolute;
		top: 16px;
		right: 16px;
		background: none;
		border: 1px solid var(--line);
		color: var(--muted);
		width: 30px;
		height: 30px;
		cursor: pointer;
		font-size: 12px;
	}
	.player-close:hover {
		color: var(--cyan);
		border-color: var(--cyan);
	}

	.player-label {
		font-size: 10px;
		letter-spacing: 0.14em;
		color: var(--cyan);
		margin-bottom: 28px;
	}

	.deck {
		width: 100%;
		aspect-ratio: 1.5;
		background: var(--bg-2);
		border: 1px solid var(--line);
		display: grid;
		place-items: center;
		margin-bottom: 24px;
		padding: 24px;
	}

	.cassette {
		position: relative;
		width: 100%;
		aspect-ratio: 1.6;
		background: #0a0f1a;
		border: 1px solid var(--line-strong);
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 14px 20px;
	}

	.cassette-window {
		display: flex;
		align-items: center;
		justify-content: space-between;
		background: rgba(120, 179, 255, 0.05);
		border: 1px solid var(--line);
		padding: 10px 18px;
		position: relative;
	}

	.tape-strip {
		position: absolute;
		left: 20%;
		right: 20%;
		top: 50%;
		height: 1px;
		background: var(--line-strong);
		transform: translateY(-50%);
	}

	.reel {
		width: 34px;
		height: 34px;
		border-radius: 50%;
		border: 1px solid var(--line-strong);
		display: grid;
		place-items: center;
		position: relative;
		z-index: 1;
		animation: reelspin 1.6s linear infinite paused;
	}
	.reel.is-spinning {
		animation-play-state: running;
	}
	.reel::before {
		content: '';
		position: absolute;
		inset: 3px;
		border-radius: 50%;
		background: repeating-conic-gradient(
			var(--bg-2) 0deg 8deg,
			rgba(120, 179, 255, 0.18) 8deg 16deg
		);
	}
	.reel-hub {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--cyan);
		position: relative;
		z-index: 1;
	}

	@keyframes reelspin {
		to {
			transform: rotate(360deg);
		}
	}

	.cassette-label {
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.cassette-label span:first-child {
		font-family: var(--display);
		font-weight: 700;
		text-transform: uppercase;
		font-size: 15px;
		color: var(--white);
	}
	.cassette-label span:last-child {
		font-size: 10px;
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.cassette-screws {
		position: absolute;
		inset: 8px;
		pointer-events: none;
	}
	.cassette-screws span {
		position: absolute;
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: var(--line-strong);
	}
	.cassette-screws span:nth-child(1) {
		top: 0;
		left: 0;
	}
	.cassette-screws span:nth-child(2) {
		top: 0;
		right: 0;
	}
	.cassette-screws span:nth-child(3) {
		bottom: 0;
		left: 0;
	}
	.cassette-screws span:nth-child(4) {
		bottom: 0;
		right: 0;
	}

	.player-meta {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 24px;
		gap: 12px;
	}
	.meta-title {
		font-family: var(--display);
		font-weight: 700;
		text-transform: uppercase;
		font-size: 20px;
		color: var(--white);
	}
	.meta-sub {
		font-size: 11px;
		color: var(--muted);
		letter-spacing: 0.04em;
		margin-top: 4px;
	}
	.format-badge {
		font-size: 10px;
		letter-spacing: 0.12em;
		color: var(--cyan);
		border: 1px solid var(--line-strong);
		padding: 5px 10px;
		flex-shrink: 0;
	}

	.player-controls {
		display: flex;
		align-items: center;
		gap: 20px;
	}
	.transport-btn {
		width: 46px;
		height: 46px;
		flex-shrink: 0;
		border: 1px solid var(--line-strong);
		background: var(--bg-2);
		color: var(--white);
		cursor: pointer;
		display: grid;
		place-items: center;
		transition:
			border-color 0.2s,
			color 0.2s;
	}
	.transport-btn svg {
		width: 16px;
		height: 16px;
	}
	.transport-btn:hover {
		border-color: var(--cyan);
		color: var(--cyan);
	}

	.scrub {
		flex: 1;
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.time {
		font-size: 11px;
		color: var(--muted);
		min-width: 36px;
	}
	.time.counter {
		font-variant-numeric: tabular-nums;
	}
	.scrub-track {
		flex: 1;
		height: 2px;
		background: var(--line);
		position: relative;
	}
	.scrub-fill {
		position: absolute;
		top: 0;
		left: 0;
		height: 100%;
		width: 0%;
		background: var(--cyan);
	}

	.player-note {
		margin-top: 18px;
		font-size: 11px;
		color: var(--faint);
		text-align: center;
	}

	@media (max-width: 560px) {
		.player-panel {
			padding: 24px 18px;
		}
	}
</style>
