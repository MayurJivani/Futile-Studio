---
// Turntable modal — populated and controlled by /collection page script.
// Expects a shared <audio id="media-audio"> to exist on the page.
---

<div class="player vinyl-player" id="vinyl-player" data-format="vinyl" aria-hidden="true">
	<div class="player-panel">
		<button class="player-close" id="vinyl-close" aria-label="Close player" data-magnetic="0.4">✕</button>

		<div class="player-label">/ TURNTABLE — DWG 01</div>

		<div class="turntable">
			<div class="platter">
				<div class="record" id="vinyl-record">
					<svg viewBox="0 0 200 200" class="grooves">
						<circle cx="100" cy="100" r="98"></circle>
						<circle cx="100" cy="100" r="88"></circle>
						<circle cx="100" cy="100" r="78"></circle>
						<circle cx="100" cy="100" r="68"></circle>
						<circle cx="100" cy="100" r="58"></circle>
						<circle cx="100" cy="100" r="48"></circle>
						<circle cx="100" cy="100" r="38"></circle>
					</svg>
					<div class="vinyl-label">
						<span id="vinyl-title">Album Title</span>
						<span id="vinyl-artist">Artist</span>
					</div>
					<div class="spindle"></div>
				</div>
			</div>
			<div class="tonearm" id="tonearm">
				<div class="tonearm-arm">
					<div class="tonearm-head"></div>
				</div>
				<div class="tonearm-pivot"></div>
			</div>
		</div>

		<div class="player-meta">
			<div>
				<div class="meta-title" id="vinyl-meta-title">Album Title</div>
				<div class="meta-sub" id="vinyl-meta-sub">Artist · Year</div>
			</div>
			<div class="format-badge">VINYL</div>
		</div>

		<div class="player-controls">
			<button class="transport-btn" id="vinyl-play" aria-label="Play / pause" data-magnetic="0.3">
				<svg id="vinyl-play-icon" viewBox="0 0 16 16" fill="currentColor"
					><path d="M4 2.5v11l10-5.5-10-5.5z"></path></svg
				>
				<svg id="vinyl-pause-icon" viewBox="0 0 16 16" fill="currentColor" style="display:none"
					><path d="M4 2.5h3v11H4zM9 2.5h3v11H9z"></path></svg
				>
			</button>
			<div class="scrub">
				<span class="time" id="vinyl-time-current">00:00</span>
				<div class="scrub-track"><div class="scrub-fill" id="vinyl-scrub-fill"></div></div>
				<span class="time" id="vinyl-time-total">00:00</span>
			</div>
		</div>

		<p class="player-note" id="vinyl-note"></p>
	</div>
</div>

<style>
	.player {
		position: fixed;
		inset: 0;
		z-index: 300;
		display: none;
		align-items: center;
		justify-content: center;
		padding: 24px;
		background: rgba(4, 8, 16, 0.86);
		backdrop-filter: blur(6px);
	}
	.player.is-open {
		display: flex;
	}

	.player-panel {
		position: relative;
		width: min(520px, 100%);
		background: var(--surface);
		border: 1px solid var(--line-strong);
		padding: 36px;
	}

	.player-close {
		position: absolute;
		top: 16px;
		right: 16px;
		background: none;
		border: 1px solid var(--line);
		color: var(--muted);
		width: 30px;
		height: 30px;
		cursor: pointer;
		font-size: 12px;
	}
	.player-close:hover {
		color: var(--cyan);
		border-color: var(--cyan);
	}

	.player-label {
		font-size: 10px;
		letter-spacing: 0.14em;
		color: var(--cyan);
		margin-bottom: 28px;
	}

	.turntable {
		position: relative;
		width: 100%;
		aspect-ratio: 1.15;
		background: var(--bg-2);
		border: 1px solid var(--line);
		display: grid;
		place-items: center;
		margin-bottom: 24px;
	}

	.platter {
		width: 62%;
		aspect-ratio: 1;
		border-radius: 50%;
		border: 1px solid var(--line-strong);
		display: grid;
		place-items: center;
	}

	.record {
		width: 92%;
		aspect-ratio: 1;
		border-radius: 50%;
		background: #0a0f1a;
		position: relative;
		display: grid;
		place-items: center;
		animation: vinylspin 2.2s linear infinite paused;
		box-shadow: 0 0 0 1px var(--line);
	}
	.record.is-spinning {
		animation-play-state: running;
	}

	@keyframes vinylspin {
		to {
			transform: rotate(360deg);
		}
	}

	.grooves {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}
	.grooves circle {
		fill: none;
		stroke: rgba(120, 179, 255, 0.16);
		stroke-width: 0.6;
	}

	.vinyl-label {
		width: 42%;
		aspect-ratio: 1;
		border-radius: 50%;
		background: var(--surface-lt);
		border: 1px solid var(--line-strong);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		gap: 4px;
		padding: 8px;
		position: relative;
		z-index: 1;
	}
	.vinyl-label span:first-child {
		font-family: var(--display);
		font-weight: 700;
		text-transform: uppercase;
		font-size: 12px;
		color: var(--white);
		line-height: 1.1;
	}
	.vinyl-label span:last-child {
		font-size: 9px;
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.spindle {
		position: absolute;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--cyan);
		z-index: 2;
	}

	.tonearm {
		position: absolute;
		top: 8%;
		right: 8%;
		width: 40%;
		height: 70%;
		pointer-events: none;
	}
	.tonearm-pivot {
		position: absolute;
		top: 0;
		right: 0;
		width: 14px;
		height: 14px;
		border-radius: 50%;
		border: 1px solid var(--line-strong);
		background: var(--bg-2);
	}
	.tonearm-arm {
		position: absolute;
		top: 6px;
		right: 6px;
		width: 2px;
		height: 88%;
		background: var(--cyan-soft);
		transform-origin: top center;
		transform: rotate(-32deg);
		transition: transform 0.6s cubic-bezier(0.65, 0, 0.35, 1);
	}
	.tonearm.is-playing .tonearm-arm {
		transform: rotate(4deg);
	}
	.tonearm-head {
		position: absolute;
		bottom: -3px;
		left: -4px;
		width: 10px;
		height: 6px;
		background: var(--cyan);
	}

	.player-meta {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 24px;
		gap: 12px;
	}
	.meta-title {
		font-family: var(--display);
		font-weight: 700;
		text-transform: uppercase;
		font-size: 20px;
		color: var(--white);
	}
	.meta-sub {
		font-size: 11px;
		color: var(--muted);
		letter-spacing: 0.04em;
		margin-top: 4px;
	}
	.format-badge {
		font-size: 10px;
		letter-spacing: 0.12em;
		color: var(--cyan);
		border: 1px solid var(--line-strong);
		padding: 5px 10px;
		flex-shrink: 0;
	}

	.player-controls {
		display: flex;
		align-items: center;
		gap: 20px;
	}
	.transport-btn {
		width: 46px;
		height: 46px;
		flex-shrink: 0;
		border: 1px solid var(--line-strong);
		background: var(--bg-2);
		color: var(--white);
		cursor: pointer;
		display: grid;
		place-items: center;
		transition:
			border-color 0.2s,
			color 0.2s;
	}
	.transport-btn svg {
		width: 16px;
		height: 16px;
	}
	.transport-btn:hover {
		border-color: var(--cyan);
		color: var(--cyan);
	}

	.scrub {
		flex: 1;
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.time {
		font-size: 11px;
		color: var(--muted);
		min-width: 36px;
	}
	.scrub-track {
		flex: 1;
		height: 2px;
		background: var(--line);
		position: relative;
	}
	.scrub-fill {
		position: absolute;
		top: 0;
		left: 0;
		height: 100%;
		width: 0%;
		background: var(--cyan);
	}

	.player-note {
		margin-top: 18px;
		font-size: 11px;
		color: var(--faint);
		text-align: center;
	}

	@media (max-width: 560px) {
		.player-panel {
			padding: 24px 18px;
		}
	}
</style>
