---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Futile Studio — Mayur Jivani',
	description = "Everything is futile at scale. We do it anyway, because there's beauty in it.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@400;600;700;800;900&family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="scroll-progress" id="scroll-progress"></div>

		<div class="rule rule-top" aria-hidden="true">
			<span>FUTILE.STUDIO</span><span>N 51.7189° / E 8.7575° — PADERBORN, DE</span>
		</div>
		<div class="mark mark-tl" aria-hidden="true">+</div>
		<div class="mark mark-tr" aria-hidden="true">+</div>
		<div class="mark mark-bl" aria-hidden="true">+</div>
		<div class="mark mark-br" aria-hidden="true">+</div>

		<slot />

		<script>
			// scroll progress
			const bar = document.getElementById('scroll-progress');
			const onScroll = () => {
				const h = document.documentElement;
				const pct = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
				if (bar) bar.style.width = pct + '%';
			};
			document.addEventListener('scroll', onScroll, { passive: true });
			onScroll();

			// reveal on scroll
			const io = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-in');
							io.unobserve(entry.target);
						}
					}
				},
				{ threshold: 0.14, rootMargin: '0px 0px -8% 0px' }
			);
			document.querySelectorAll('[data-reveal]').forEach((el, i) => {
				(el as HTMLElement).style.setProperty('--d', `${(i % 6) * 70}ms`);
				io.observe(el);
			});
		</script>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	:root {
		--bg: #060c18;
		--bg-2: #0a1526;
		--surface: #0d1c33;
		--surface-lt: #112342;
		--line: rgba(120, 179, 255, 0.14);
		--line-strong: rgba(120, 179, 255, 0.32);
		--cyan: #5eb8ff;
		--cyan-soft: #a9d3ff;
		--white: #eef4fb;
		--muted: #7e93b8;
		--faint: #3a4d70;
		--red: #ff5b45;

		--display: 'Big Shoulders Display', 'Arial Narrow', sans-serif;
		--mono: 'JetBrains Mono', 'Space Mono', 'Courier New', monospace;
	}

	html {
		scroll-behavior: smooth;
		overflow-x: hidden;
		width: 100%;
	}

	body {
		background: var(--bg);
		background-image:
			linear-gradient(var(--line) 1px, transparent 1px),
			linear-gradient(90deg, var(--line) 1px, transparent 1px),
			linear-gradient(rgba(120, 179, 255, 0.06) 1px, transparent 1px),
			linear-gradient(90deg, rgba(120, 179, 255, 0.06) 1px, transparent 1px);
		background-size:
			160px 160px,
			160px 160px,
			20px 20px,
			20px 20px;
		background-position: -1px -1px;
		color: var(--white);
		font-family: var(--mono);
		font-size: 14px;
		line-height: 1.7;
		min-height: 100vh;
		overflow-x: hidden;
	}

	/* grain */
	body::before {
		content: '';
		position: fixed;
		inset: 0;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
		opacity: 0.035;
		pointer-events: none;
		z-index: 999;
	}

	::selection {
		background: var(--cyan);
		color: var(--bg);
	}

	a {
		color: inherit;
	}

	h1,
	h2,
	h3 {
		font-family: var(--display);
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: -0.01em;
	}

	/* top identification rule, blueprint titleblock style */
	.rule-top {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 90;
		display: flex;
		justify-content: space-between;
		padding: 8px 20px;
		font-size: 9px;
		letter-spacing: 0.14em;
		color: var(--faint);
		border-bottom: 1px solid var(--line);
		background: rgba(6, 12, 24, 0.6);
		backdrop-filter: blur(4px);
		pointer-events: none;
	}

	.scroll-progress {
		position: fixed;
		top: 0;
		left: 0;
		height: 2px;
		width: 0%;
		background: var(--cyan);
		box-shadow: 0 0 8px var(--cyan);
		z-index: 200;
		transition: width 0.05s linear;
	}

	.mark {
		position: fixed;
		z-index: 91;
		color: var(--faint);
		font-size: 14px;
		pointer-events: none;
		font-family: var(--mono);
	}
	.mark-tl {
		top: 22px;
		left: 6px;
	}
	.mark-tr {
		top: 22px;
		right: 6px;
	}
	.mark-bl {
		bottom: 6px;
		left: 6px;
	}
	.mark-br {
		bottom: 6px;
		right: 6px;
	}

	@media (max-width: 768px) {
		.rule-top span:last-child {
			display: none;
		}
	}

	/* shared reveal-on-scroll */
	[data-reveal] {
		opacity: 0;
		transform: translateY(28px);
		transition:
			opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
			transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
		transition-delay: var(--d, 0ms);
	}
	[data-reveal].is-in {
		opacity: 1;
		transform: translateY(0);
	}
	[data-reveal='line'] {
		transform: none;
	}
	[data-reveal='line'] .draw-path {
		stroke-dasharray: 1;
		stroke-dashoffset: 1;
		transition: stroke-dashoffset 1.1s cubic-bezier(0.16, 1, 0.3, 1);
		transition-delay: var(--d, 0ms);
	}
	[data-reveal='line'].is-in .draw-path {
		stroke-dashoffset: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		[data-reveal] {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}
</style>
