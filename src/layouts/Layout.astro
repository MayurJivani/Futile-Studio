---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Futile Studio — Mayur Jivani',
	description = "Everything is futile at scale. We do it anyway, because there's beauty in it.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@400;600;700;800;900&family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- PRELOADER -->
		<div class="preloader" id="preloader" aria-hidden="true">
			<svg class="preloader-diagram" viewBox="0 0 200 200" fill="none">
				<circle cx="100" cy="100" r="70" stroke="currentColor" stroke-width="0.6"></circle>
				<circle cx="100" cy="100" r="46" stroke="currentColor" stroke-width="0.6"></circle>
				<circle cx="100" cy="100" r="22" stroke="currentColor" stroke-width="0.6"></circle>
				<line
					x1="100"
					y1="10"
					x2="100"
					y2="190"
					stroke="currentColor"
					stroke-width="0.4"
					stroke-dasharray="2 6"></line>
				<line
					x1="10"
					y1="100"
					x2="190"
					y2="100"
					stroke="currentColor"
					stroke-width="0.4"
					stroke-dasharray="2 6"></line>
			</svg>
			<div class="preloader-tag" id="preloader-tag">INITIALIZING STUDIO</div>
			<div class="preloader-count"><span id="preloader-pct">00</span><span>%</span></div>
			<div class="preloader-bar"><div class="preloader-bar-fill" id="preloader-bar-fill"></div></div>
		</div>

		<!-- CUSTOM CURSOR -->
		<div class="cursor" id="cursor" aria-hidden="true">
			<div class="cursor-ring" id="cursor-ring"></div>
			<div class="cursor-dot" id="cursor-dot"></div>
			<div class="cursor-coord" id="cursor-coord">X 0000 · Y 0000</div>
		</div>

		<!-- HOVER GLIMPSE (project preview overlay) -->
		<div class="glimpse" id="glimpse" aria-hidden="true">
			<div class="glimpse-panel">
				<div class="glimpse-label">/ PREVIEW</div>
				<div class="glimpse-inner" id="glimpse-inner"></div>
			</div>
		</div>

		<div class="scroll-progress" id="scroll-progress"></div>

		<div class="rule rule-top" aria-hidden="true">
			<span>FUTILE.STUDIO</span><span>N 51.7189° / E 8.7575° — PADERBORN, DE</span>
		</div>
		<div class="mark mark-tl" aria-hidden="true">+</div>
		<div class="mark mark-tr" aria-hidden="true">+</div>
		<div class="mark mark-bl" aria-hidden="true">+</div>
		<div class="mark mark-br" aria-hidden="true">+</div>

		<slot />

		<script>
			import { gsap } from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';
			gsap.registerPlugin(ScrollTrigger);

			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

			/* ---------- preloader ---------- */
			(function preloader() {
				const el = document.getElementById('preloader')!;
				const pct = document.getElementById('preloader-pct')!;
				const bar = document.getElementById('preloader-bar-fill')!;
				const tag = document.getElementById('preloader-tag')!;
				const fast = sessionStorage.getItem('futile-visited') === '1';

				document.body.classList.add('is-loading');

				const finish = () => {
					document.body.classList.remove('is-loading');
					sessionStorage.setItem('futile-visited', '1');
					gsap.to(el, {
						yPercent: -100,
						duration: fast || reduceMotion ? 0.35 : 0.9,
						ease: 'power4.inOut',
						onComplete: () => el.remove(),
					});
				};

				if (reduceMotion || fast) {
					pct.textContent = '100';
					bar.style.width = '100%';
					gsap.delayedCall(0.15, finish);
					return;
				}

				const tags = ['INITIALIZING STUDIO', 'LOADING ASSETS', 'EVERYTHING IS FUTILE', 'DO IT ANYWAY'];
				const proxy = { v: 0 };
				gsap.to(proxy, {
					v: 100,
					duration: 1.5,
					ease: 'power2.inOut',
					onUpdate: () => {
						const v = Math.round(proxy.v);
						pct.textContent = String(v).padStart(2, '0');
						bar.style.width = v + '%';
						const idx = Math.min(tags.length - 1, Math.floor((v / 100) * tags.length));
						if (tag.textContent !== tags[idx]) tag.textContent = tags[idx];
					},
					onComplete: () => gsap.delayedCall(0.25, finish),
				});
			})();

			/* ---------- custom cursor ---------- */
			if (canHover && !reduceMotion) {
				document.documentElement.classList.add('has-custom-cursor');
				const cursor = document.getElementById('cursor')!;
				const ring = document.getElementById('cursor-ring')!;
				const dot = document.getElementById('cursor-dot')!;
				const coord = document.getElementById('cursor-coord')!;

				const dotX = gsap.quickTo(dot, 'x', { duration: 0.08, ease: 'power3' });
				const dotY = gsap.quickTo(dot, 'y', { duration: 0.08, ease: 'power3' });
				const ringX = gsap.quickTo(ring, 'x', { duration: 0.35, ease: 'power3' });
				const ringY = gsap.quickTo(ring, 'y', { duration: 0.35, ease: 'power3' });

				window.addEventListener(
					'mousemove',
					(e) => {
						cursor.classList.add('has-moved');
						dotX(e.clientX);
						dotY(e.clientY);
						ringX(e.clientX);
						ringY(e.clientY);
						coord.style.transform = `translate(${e.clientX + 18}px, ${e.clientY + 14}px)`;
						coord.textContent = `X ${String(Math.round(e.clientX)).padStart(4, '0')} · Y ${String(Math.round(e.clientY)).padStart(4, '0')}`;
					},
					{ once: false },
				);

				document.addEventListener('mouseover', (e) => {
					const target = (e.target as HTMLElement).closest('a, button, [data-magnetic], .shelf-tile');
					cursor.classList.toggle('is-active', !!target);
				});
			}

			/* ---------- magnetic elements ---------- */
			if (canHover && !reduceMotion) {
				document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((el) => {
					const strength = parseFloat(el.dataset.magnetic || '0.35');
					const xTo = gsap.quickTo(el, 'x', { duration: 0.5, ease: 'power3' });
					const yTo = gsap.quickTo(el, 'y', { duration: 0.5, ease: 'power3' });
					el.addEventListener('mousemove', (e) => {
						const r = el.getBoundingClientRect();
						xTo((e.clientX - r.left - r.width / 2) * strength);
						yTo((e.clientY - r.top - r.height / 2) * strength);
					});
					el.addEventListener('mouseleave', () => {
						xTo(0);
						yTo(0);
					});
				});
			}

			/* ---------- hover glimpse (project preview overlay) ---------- */
			if (canHover && !reduceMotion) {
				const glimpse = document.getElementById('glimpse')!;
				const glimpseInner = document.getElementById('glimpse-inner')!;
				const gX = gsap.quickTo(glimpse, 'x', { duration: 0.4, ease: 'power3' });
				const gY = gsap.quickTo(glimpse, 'y', { duration: 0.4, ease: 'power3' });
				let activeGlimpse: HTMLElement | null = null;

				function positionGlimpse(clientX: number, clientY: number) {
					const panelW = 300;
					const panelH = 220;
					let x = clientX + 30;
					let y = clientY + 30;
					if (x + panelW > window.innerWidth - 16) x = clientX - panelW - 30;
					if (y + panelH > window.innerHeight - 16) y = clientY - panelH - 30;
					gX(x);
					gY(y);
				}

				document.addEventListener('mouseover', (e) => {
					const card = (e.target as HTMLElement).closest<HTMLElement>('[data-glimpse]');
					if (card && card !== activeGlimpse) {
						activeGlimpse = card;
						const tpl = card.querySelector('template');
						glimpseInner.innerHTML = '';
						if (tpl) glimpseInner.appendChild((tpl as HTMLTemplateElement).content.cloneNode(true));
						glimpse.classList.add('is-visible');
					} else if (!card && activeGlimpse) {
						activeGlimpse = null;
						glimpse.classList.remove('is-visible');
					}
				});

				window.addEventListener('mousemove', (e) => {
					if (activeGlimpse) positionGlimpse(e.clientX, e.clientY);
				});
			}

			/* ---------- auto word-split for [data-split] ---------- */
			document.querySelectorAll<HTMLElement>('[data-split]').forEach((el) => {
				const words = el.textContent!.trim().split(/\s+/);
				el.innerHTML = words
					.map((w) => `<span class="split-mask"><span class="split-word">${w}</span></span> `)
					.join('');
			});

			/* ---------- scroll reveal (fade/rise) ---------- */
			gsap.utils.toArray<HTMLElement>('[data-reveal]:not([data-reveal="line"])').forEach((el) => {
				const delay = (parseFloat(getComputedStyle(el).getPropertyValue('--d')) || 0) / 1000;
				gsap.set(el, { opacity: 0, y: 28 });
				gsap.to(el, {
					opacity: 1,
					y: 0,
					duration: 0.8,
					delay,
					ease: 'power3.out',
					scrollTrigger: { trigger: el, start: 'top 88%' },
				});
			});

			/* ---------- scroll reveal (drawn lines) ---------- */
			gsap.utils
				.toArray<SVGPathElement | SVGLineElement>('[data-reveal="line"] .draw-path')
				.forEach((path) => {
					gsap.set(path, { strokeDashoffset: 1 });
					gsap.to(path, {
						strokeDashoffset: 0,
						duration: 1.1,
						ease: 'power3.out',
						scrollTrigger: { trigger: path, start: 'top 92%' },
					});
				});

			/* ---------- kinetic word reveal ---------- */
			document.querySelectorAll<HTMLElement>('[data-split-group]').forEach((group) => {
				const words = group.querySelectorAll('.split-word');
				if (!words.length) return;
				gsap.set(words, { yPercent: 120 });
				gsap.to(words, {
					yPercent: 0,
					duration: 0.9,
					stagger: 0.045,
					ease: 'power4.out',
					scrollTrigger: { trigger: group, start: 'top 85%' },
				});
			});

			/* ---------- scroll progress ---------- */
			const bar = document.getElementById('scroll-progress');
			const onScroll = () => {
				const h = document.documentElement;
				const p = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
				if (bar) bar.style.width = p + '%';
			};
			document.addEventListener('scroll', onScroll, { passive: true });
			onScroll();

			window.addEventListener('load', () => ScrollTrigger.refresh());
		</script>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	:root {
		--bg: #060c18;
		--bg-2: #0a1526;
		--surface: #0d1c33;
		--surface-lt: #112342;
		--line: rgba(120, 179, 255, 0.14);
		--line-strong: rgba(120, 179, 255, 0.32);
		--cyan: #5eb8ff;
		--cyan-soft: #a9d3ff;
		--white: #eef4fb;
		--muted: #7e93b8;
		--faint: #3a4d70;
		--red: #ff5b45;

		--display: 'Big Shoulders Display', 'Arial Narrow', sans-serif;
		--mono: 'JetBrains Mono', 'Space Mono', 'Courier New', monospace;
	}

	html {
		scroll-behavior: smooth;
		overflow-x: hidden;
		width: 100%;
	}

	html.has-custom-cursor,
	html.has-custom-cursor a,
	html.has-custom-cursor button {
		cursor: none;
	}

	body {
		background: var(--bg);
		background-image:
			linear-gradient(var(--line) 1px, transparent 1px),
			linear-gradient(90deg, var(--line) 1px, transparent 1px),
			linear-gradient(rgba(120, 179, 255, 0.06) 1px, transparent 1px),
			linear-gradient(90deg, rgba(120, 179, 255, 0.06) 1px, transparent 1px);
		background-size:
			160px 160px,
			160px 160px,
			20px 20px,
			20px 20px;
		background-position: -1px -1px;
		color: var(--white);
		font-family: var(--mono);
		font-size: 14px;
		line-height: 1.7;
		min-height: 100vh;
		overflow-x: hidden;
	}

	body.is-loading {
		overflow: hidden;
		height: 100vh;
	}

	/* grain */
	body::before {
		content: '';
		position: fixed;
		inset: 0;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
		opacity: 0.035;
		pointer-events: none;
		z-index: 999;
	}

	::selection {
		background: var(--cyan);
		color: var(--bg);
	}

	a {
		color: inherit;
	}

	/* shared CTA button, used across pages (hero, forms, editor) */
	.hero-cta {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		border: 1px solid var(--line-strong);
		background: none;
		color: var(--white);
		text-decoration: none;
		padding: 13px 26px;
		font-size: 12px;
		font-family: var(--mono);
		letter-spacing: 0.1em;
		text-transform: uppercase;
		cursor: pointer;
		transition:
			border-color 0.2s,
			color 0.2s,
			background 0.2s;
	}

	.hero-cta:hover {
		border-color: var(--cyan);
		color: var(--cyan);
		background: rgba(94, 184, 255, 0.06);
	}

	.hero-cta svg {
		width: 14px;
		height: 14px;
	}

	h1,
	h2,
	h3 {
		font-family: var(--display);
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: -0.01em;
	}

	/* ---------- preloader ---------- */
	.preloader {
		position: fixed;
		inset: 0;
		z-index: 1000;
		background: var(--bg);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 20px;
	}
	.preloader-diagram {
		width: 90px;
		height: 90px;
		color: var(--cyan);
		opacity: 0.5;
		animation: spin 6s linear infinite;
	}
	.preloader-tag {
		font-size: 11px;
		letter-spacing: 0.16em;
		color: var(--muted);
		text-transform: uppercase;
		height: 14px;
	}
	.preloader-count {
		font-family: var(--display);
		font-weight: 800;
		font-size: 56px;
		color: var(--white);
		line-height: 1;
	}
	.preloader-count span:last-child {
		font-size: 20px;
		color: var(--cyan);
		margin-left: 4px;
	}
	.preloader-bar {
		width: 220px;
		height: 1px;
		background: var(--line);
	}
	.preloader-bar-fill {
		height: 100%;
		width: 0%;
		background: var(--cyan);
		box-shadow: 0 0 8px var(--cyan);
	}

	@keyframes spin {
		to {
			transform: rotate(360deg);
		}
	}

	/* ---------- custom cursor ---------- */
	.cursor {
		display: none;
	}
	.has-custom-cursor .cursor {
		display: block;
	}
	.cursor-dot,
	.cursor-ring,
	.cursor-coord {
		position: fixed;
		top: 0;
		left: 0;
		pointer-events: none;
		z-index: 500;
		will-change: transform;
	}
	.cursor-dot {
		width: 6px;
		height: 6px;
		margin: -3px;
		border-radius: 50%;
		background: var(--cyan);
	}
	.cursor-ring {
		width: 34px;
		height: 34px;
		margin: -17px;
		border-radius: 50%;
		border: 1px solid var(--line-strong);
		transition:
			width 0.25s,
			height 0.25s,
			margin 0.25s,
			border-color 0.25s,
			background 0.25s;
	}
	.cursor.is-active .cursor-ring {
		width: 54px;
		height: 54px;
		margin: -27px;
		border-color: var(--cyan);
		background: rgba(94, 184, 255, 0.08);
	}
	.cursor-coord {
		font-size: 9px;
		letter-spacing: 0.06em;
		color: var(--cyan-soft);
		opacity: 0;
		white-space: nowrap;
		transition: opacity 0.3s;
	}
	.cursor.has-moved .cursor-coord {
		opacity: 0.55;
	}

	/* ---------- hover glimpse (project preview overlay) ---------- */
	.glimpse {
		position: fixed;
		top: 0;
		left: 0;
		z-index: 400;
		width: 300px;
		pointer-events: none;
		opacity: 0;
		transform: scale(0.96);
		transition:
			opacity 0.25s cubic-bezier(0.16, 1, 0.3, 1),
			transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.glimpse.is-visible {
		opacity: 1;
		transform: scale(1);
	}
	.glimpse-panel {
		border: 1px solid var(--line-strong);
		background: var(--surface);
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
		padding: 16px;
	}
	.glimpse-label {
		font-size: 9px;
		letter-spacing: 0.14em;
		color: var(--cyan);
		margin-bottom: 10px;
	}
	.glimpse-inner svg {
		width: 100%;
		height: auto;
		display: block;
		color: var(--cyan-soft);
	}
	.glimpse-inner .glimpse-tag {
		margin-top: 10px;
		font-size: 10px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
	}

	@media (max-width: 900px) {
		.glimpse {
			display: none;
		}
	}

	/* top identification rule, blueprint titleblock style */
	.rule-top {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 90;
		display: flex;
		justify-content: space-between;
		padding: 8px 20px;
		font-size: 9px;
		letter-spacing: 0.14em;
		color: var(--faint);
		border-bottom: 1px solid var(--line);
		background: rgba(6, 12, 24, 0.6);
		backdrop-filter: blur(4px);
		pointer-events: none;
	}

	.scroll-progress {
		position: fixed;
		top: 0;
		left: 0;
		height: 2px;
		width: 0%;
		background: var(--cyan);
		box-shadow: 0 0 8px var(--cyan);
		z-index: 200;
		transition: width 0.05s linear;
	}

	.mark {
		position: fixed;
		z-index: 91;
		color: var(--faint);
		font-size: 14px;
		pointer-events: none;
		font-family: var(--mono);
	}
	.mark-tl {
		top: 22px;
		left: 6px;
	}
	.mark-tr {
		top: 22px;
		right: 6px;
	}
	.mark-bl {
		bottom: 6px;
		left: 6px;
	}
	.mark-br {
		bottom: 6px;
		right: 6px;
	}

	@media (max-width: 768px) {
		.rule-top span:last-child {
			display: none;
		}
	}

	/* ---------- split text (kinetic word reveal) ---------- */
	.split-mask {
		display: inline-block;
		overflow: hidden;
		vertical-align: top;
		padding-bottom: 0.08em;
	}
	.split-word {
		display: inline-block;
		will-change: transform;
	}

	@media (prefers-reduced-motion: reduce) {
		[data-reveal] {
			opacity: 1 !important;
			transform: none !important;
		}
		.split-word {
			transform: none !important;
		}
	}
</style>
